# ============================================
# Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Admin Password (set a strong password)
ADMIN_PASSWORD=your-secure-admin-password-here

# Optional: Paystack Configuration (for server-side use only)
# PAYSTACK_SECRET_KEY=sk_test_your-secret-key-here
# PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# Optional: Flutterwave Configuration
# FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret